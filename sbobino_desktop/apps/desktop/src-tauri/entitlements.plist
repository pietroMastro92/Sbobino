<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <!-- PyTorch uses JIT and maps executable pages; without these the
       bundled pyannote helper crashes under the hardened runtime on
       notarized builds. -->
  <key>com.apple.security.cs.allow-jit</key>
  <true/>
  <key>com.apple.security.cs.allow-unsigned-executable-memory</key>
  <true/>
  <key>com.apple.security.cs.disable-executable-page-protection</key>
  <true/>
  <!-- Bundled CPython + torch dylibs are ad-hoc signed after patching
       @rpath entries; disable library validation so they load. -->
  <key>com.apple.security.cs.disable-library-validation</key>
  <true/>
  <!-- The pyannote helper launcher sets PYTHONHOME / PYTHONPATH before
       exec to isolate from the host Python install. -->
  <key>com.apple.security.cs.allow-dyld-environment-variables</key>
  <true/>
  <!-- Live transcription requires microphone capture. -->
  <key>com.apple.security.device.audio-input</key>
  <true/>
</dict>
</plist>
